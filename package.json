{
  "name": "audiobatch",
  "version": "1.0.0",
  "description": "Batch audio rename and convert tool for macOS",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "start": "concurrently \"BROWSER=none react-scripts start\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "react-scripts build",
    "electron": "electron .",
    "dist": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "electron": "^42.4.1",
    "electron-builder": "^24.6.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.audiobatch.app",
    "productName": "AudioBatch",
    "mac": {
      "category": "public.app-category.music",
      "icon": "public/icon.icns"
    },
    "files": [
      "build/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version"
    ]
  }
}
